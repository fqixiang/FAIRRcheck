<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>FAIRR Report — {{ result.project_name }}</title>
<style>
  :root {
    --fairr-blue: #0066cc;
    --surf-orange: #e85d04;
    --bg: #f5f7fa;
    --card-bg: #ffffff;
    --border: #dce1e9;
    --text: #1a1a2e;
    --muted: #6b7280;
    --green: #059669;
    --amber: #d97706;
    --red: #dc2626;
    --radius: 8px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 14px;
    line-height: 1.6;
  }

  header {
    background: var(--fairr-blue);
    color: #fff;
    padding: 24px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  header h1 { font-size: 1.5rem; font-weight: 700; }
  header .subtitle { font-size: 0.85rem; opacity: 0.8; }
  header .badge {
    background: rgba(255,255,255,0.2);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  main { max-width: 1100px; margin: 0 auto; padding: 32px 24px; }

  /* ---- Overview card ---- */
  .overview {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px 32px;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .score-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 800;
    border: 6px solid;
    flex-shrink: 0;
  }
  .score-circle .grade-label { font-size: 0.7rem; font-weight: 600; letter-spacing: 1px; }

  .score-A  { border-color: var(--green);  color: var(--green); }
  .score-B  { border-color: #16a34a; color: #16a34a; }
  .score-C  { border-color: var(--amber);  color: var(--amber); }
  .score-D  { border-color: var(--surf-orange); color: var(--surf-orange); }
  .score-F  { border-color: var(--red);    color: var(--red);  }

  .overview-meta { flex: 1; min-width: 220px; }
  .overview-meta h2 { font-size: 1.1rem; margin-bottom: 6px; }
  .overview-meta dl { display: grid; grid-template-columns: 140px 1fr; gap: 2px 8px; }
  .overview-meta dt { color: var(--muted); font-size: 0.82rem; }
  .overview-meta dd { font-size: 0.82rem; font-weight: 500; }

  /* ---- Principle bars ---- */
  .principle-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
  }

  .principle-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .principle-card .p-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.5px;
  }

  .principle-card .p-name {
    font-size: 0.78rem;
    color: var(--muted);
    margin-top: -4px;
  }

  .progress-bar {
    height: 8px;
    background: var(--bg);
    border-radius: 4px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.4s ease;
  }

  .fill-green  { background: var(--green); }
  .fill-amber  { background: var(--amber); }
  .fill-red    { background: var(--red); }
  .fill-orange { background: var(--surf-orange); }

  /* ---- Metrics table ---- */
  section h2 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 2px solid var(--fairr-blue);
    color: var(--fairr-blue);
  }

  .metrics-section { margin-bottom: 32px; }

  .metrics-grid {
    display: grid;
    gap: 10px;
  }

  .metric-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 18px;
    display: grid;
    grid-template-columns: 110px 1fr auto;
    gap: 8px 14px;
    align-items: start;
  }

  .metric-card.not-impl {
    opacity: 0.6;
    background: #f9fafb;
  }

  .metric-id {
    font-family: 'Courier New', monospace;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--fairr-blue);
    padding-top: 2px;
  }

  .metric-body h3 { font-size: 0.88rem; font-weight: 600; margin-bottom: 3px; }
  .metric-body .rationale { font-size: 0.8rem; color: var(--muted); }

  .metric-body .evidence {
    margin-top: 4px;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .evidence-tag {
    background: #eff6ff;
    color: var(--fairr-blue);
    border-radius: 4px;
    padding: 1px 6px;
    font-size: 0.72rem;
  }

  .metric-score {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    min-width: 46px;
  }

  .score-dots {
    display: flex;
    gap: 3px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--border);
  }

  .dot.filled-0 { background: var(--red); }
  .dot.filled-1 { background: var(--amber); }
  .dot.filled-2 { background: var(--green); }
  .dot.active   { background: var(--fairr-blue); }

  .score-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--muted);
  }

  .llm-badge {
    font-size: 0.65rem;
    background: #f0fdf4;
    color: #166534;
    border: 1px solid #bbf7d0;
    border-radius: 4px;
    padding: 1px 5px;
  }

  .null-score {
    font-size: 0.75rem;
    color: var(--muted);
    font-style: italic;
  }

  footer {
    text-align: center;
    padding: 20px;
    color: var(--muted);
    font-size: 0.75rem;
    border-top: 1px solid var(--border);
    margin-top: 20px;
  }
</style>
</head>
<body>

<header>
  <div>
    <h1>FAIRR Compliance Report</h1>
    <div class="subtitle">{{ result.registry_name }} — {{ result.scan_mode | title }} Mode</div>
  </div>
  <div class="badge">Grade {{ result.grade }} &nbsp;·&nbsp; {{ (result.overall_fairr_score * 100) | round(1) }}%</div>
</header>

<main>

  <!-- ---- Overview ---- -->
  <div class="overview">
    <div class="score-circle score-{{ result.grade }}">
      {{ (result.overall_fairr_score * 100) | round(0) | int }}%
      <span class="grade-label">{{ result.grade }}</span>
    </div>
    <div class="overview-meta">
      <h2>{{ result.project_name }}</h2>
      <dl>
        <dt>Path</dt>        <dd>{{ result.project_path }}</dd>
        <dt>Scanned at</dt>  <dd>{{ result.scanned_at[:19].replace('T', ' ') }} UTC</dd>
        <dt>Mode</dt>        <dd>{{ result.scan_mode }}</dd>
        <dt>LLM used</dt>    <dd>{{ "Yes" if result.llm_used else "No" }}</dd>
        <dt>Registry</dt>    <dd>{{ result.registry_name }} v{{ result.schema_version }}</dd>
      </dl>
    </div>
  </div>

  <!-- ---- Per-principle bars ---- -->
  <div class="principle-grid">
    {% for p, data in result.principles.items() %}
    {% set pct = (data.normalised_score * 100) | round(0) | int %}
    {% set fill = "fill-green" if pct >= 70 else ("fill-amber" if pct >= 40 else "fill-red") %}
    <div class="principle-card">
      <div class="p-label">
        <span>{{ p }}</span>
        <span>{{ pct }}%</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill {{ fill }}" style="width: {{ pct }}%"></div>
      </div>
      <div class="p-name">
        {{ {"F":"Findable","A":"Accessible","I":"Interoperable","R":"Reusable","R2":"Reproducible"}.get(p, p) }}
        &nbsp;·&nbsp; weight {{ (data.weight * 100) | round(0) | int }}%
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- ---- Metrics by principle ---- -->
  {% for principle in result.principles.keys() %}
  {% set p_metrics = result.metrics | selectattr("principle", "equalto", principle) | list %}
  {% if p_metrics %}
  <section class="metrics-section">
    <h2>
      {{ principle }} — {{ {"F":"Findable","A":"Accessible","I":"Interoperable","R":"Reusable","R2":"Reproducible"}.get(principle, principle) }}
    </h2>
    <div class="metrics-grid">
      {% for m in p_metrics %}
      <div class="metric-card {% if not m.implemented %}not-impl{% endif %}">

        <div class="metric-id">{{ m.metric_id }}</div>

        <div class="metric-body">
          <h3>{{ m.name }}</h3>
          {% if m.rationale %}
          <div class="rationale">{{ m.rationale }}</div>
          {% endif %}
          {% if m.notes %}
          <div class="rationale">{{ m.notes }}</div>
          {% endif %}
          {% if m.evidence %}
          <div class="evidence">
            {% for ev in m.evidence %}
            <span class="evidence-tag">{{ ev }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </div>

        <div class="metric-score">
          {% if m.score is not none %}
          <div class="score-dots">
            {% for i in range(m.max_score + 1) %}
            <div class="dot {% if i <= m.score %}filled-{{ m.score }}{% endif %}"></div>
            {% endfor %}
          </div>
          <div class="score-num">{{ m.score }}/{{ m.max_score }}</div>
          {% if m.llm_used %}
          <span class="llm-badge">LLM ↑</span>
          {% endif %}
          {% else %}
          <div class="null-score">N/A</div>
          {% endif %}
        </div>

      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}
  {% endfor %}

</main>

<footer>
  Generated by fairrcheck &nbsp;·&nbsp; FAIRR-HPC v{{ result.schema_version }}
  &nbsp;·&nbsp; {{ result.scanned_at[:10] }}
</footer>

</body>
</html>
